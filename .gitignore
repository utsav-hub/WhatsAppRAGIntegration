## .gitignore for WhatsAppDev (.NET backend + React admin UI)

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Common IDE folders
.vs/
.vscode/
.idea/

# Admin UI
admin-ui/node_modules/
admin-ui/dist/

# Uploaded/temp files
App_Data/
app_data/
App_Data/uploads/

# Secrets / credentials (do not commit)
appsettings.json
appsettings.Development.json
.env*
secrets*.json
*credentials*.json
